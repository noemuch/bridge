#!/usr/bin/env bash
# Bridge SessionStart hook. Injects skills/using-bridge/SKILL.md into the
# LLM system prompt at session start and appends a one-line health summary.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_FILE="$SCRIPT_DIR/../skills/using-bridge/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":""}}\n'
  exit 0
fi

SKILL_BODY="$(awk 'BEGIN{fm=0} /^---$/{fm++; next} fm>=2{print}' "$SKILL_FILE")"

HEALTH=""
if [ -f "docs.config.yaml" ]; then
  KB_STATE_FILE=".bridge/docs-state.json"
  if [ -f "$KB_STATE_FILE" ]; then
    LAST_SYNC="$(python3 -c "
import json, sys, datetime
try:
    with open('$KB_STATE_FILE') as f:
        s = json.load(f)
    ts = s.get('lastSyncAt', '')
    if ts:
        dt = datetime.datetime.fromisoformat(ts.replace('Z', '+00:00'))
        now = datetime.datetime.now(datetime.timezone.utc)
        delta = now - dt
        hours = int(delta.total_seconds() / 3600)
        if hours < 1:
            print('just now')
        elif hours < 24:
            print(f'{hours}h ago')
        else:
            print(f'{hours // 24}d ago')
    else:
        print('never')
except Exception:
    print('')
" 2>/dev/null || echo "")"
    if [ -n "$LAST_SYNC" ] && [ "$LAST_SYNC" != "never" ]; then
      COMP_COUNT="$(python3 -c "
import json, sys
try:
    with open('bridge-ds/knowledge-base/registries/components.json') as f:
        print(len(json.load(f).get('components', [])))
except Exception:
    print('?')
" 2>/dev/null || echo "?")"
      HEALTH="◆ Bridge: KB synced $LAST_SYNC · $COMP_COUNT components"
    else
      HEALTH="◆ Bridge: scaffolded but not yet extracted · run \"setup bridge\""
    fi
  else
    HEALTH="◆ Bridge: scaffolded but not yet extracted · run \"setup bridge\""
  fi
else
  HEALTH="◆ Bridge: not set up yet · run \"setup bridge\" to initialize"
fi

COMBINED="$SKILL_BODY"
if [ -n "$HEALTH" ]; then
  COMBINED="$COMBINED

---

$HEALTH"
fi

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":%s}}\n' \
  "$(printf '%s' "$COMBINED" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")"
