---
name: {{name}}
category: {{category}}
status: {{status}}
{{#if since}}since: {{since}}{{/if}}
{{#if figma}}figma: {{figma}}{{/if}}
{{#if a11y}}a11y: {{a11y}}{{/if}}
{{#if related}}related:
  {{#if related.alternatives}}alternatives: [{{join related.alternatives ", "}}]{{/if}}
  {{#if related.composesWith}}composes-with: [{{join related.composesWith ", "}}]{{/if}}
  {{#if related.supersedes}}supersedes: [{{join related.supersedes ", "}}]{{/if}}
{{/if}}
{{#if tokens}}tokens:
  {{#if tokens.color}}color: [{{join tokens.color ", "}}]{{/if}}
  {{#if tokens.spacing}}spacing: [{{join tokens.spacing ", "}}]{{/if}}
  {{#if tokens.radius}}radius: [{{join tokens.radius ", "}}]{{/if}}
  {{#if tokens.text}}text: [{{join tokens.text ", "}}]{{/if}}
{{/if}}
{{#if generated-from}}generated-from:
  kb-version: {{generated-from.kb-version}}
  registries-hash: {{generated-from.registries-hash}}
  {{#if generated-from.learnings-hash}}learnings-hash: {{generated-from.learnings-hash}}{{/if}}
  {{#if generated-from.last-ship}}last-ship: {{generated-from.last-ship}}{{/if}}
{{/if}}
last-regenerated: {{last-regenerated}}
{{#if ships}}ships: {{ships}}{{/if}}
{{#if learnings-applied}}learnings-applied: {{learnings-applied}}{{/if}}
---

