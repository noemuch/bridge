{
  "name": "@noemuch/bridge-ds",
  "version": "4.1.0",
  "description": "Compiler-driven design generation in Figma — 100% design system compliant. Compiles component specs into verified Figma output via MCP.",
  "main": "lib/cli.js",
  "bin": {
    "bridge-ds": "./bin/bridge.js"
  },
  "files": [
    "bin/",
    "lib/",
    "dist/",
    "skills/",
    "commands/",
    "hooks/",
    "references/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "MIGRATION.md",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".mcp.json",
    "CLAUDE.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node bin/bridge.js help",
    "test:skills": "node scripts/validate-skills.js",
    "test:all": "npm run build && node --test dist/lib/**/*.test.js dist/test/**/*.test.js",
    "test:security": "npm run build && node --test dist/test/security/*.test.js",
    "prepublishOnly": "npm run build && npm run test:skills && npm run test:security"
  },
  "keywords": [
    "claude-code",
    "figma",
    "design-system",
    "mcp",
    "design-tokens",
    "ai-design",
    "figma-plugin-api",
    "claude-code-plugin",
    "cursor-plugin"
  ],
  "author": "noemuch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noemuch/bridge.git"
  },
  "homepage": "https://github.com/noemuch/bridge",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "figlet": "^1.7.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/handlebars": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0"
  }
}
